# Common
APP_ENV=local
TRACE_SAMPLE_RATE=1.0

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_knowledge
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_local_password
DATABASE_URL=postgresql://agent:agent_local_password@localhost:5432/agent_knowledge
DB_URL=jdbc:postgresql://localhost:5432/agent_knowledge
DB_USERNAME=agent
DB_PASSWORD=agent_local_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Backend Java
SERVER_PORT=8080
BACKEND_PORT=8080
AI_SERVICE_BASE_URL=http://localhost:8001
AI_SERVICE_MOCK_ENABLED=false

# AI Service
AI_SERVICE_PORT=8001
AI_DATABASE_URL=postgresql://agent:agent_local_password@localhost:5432/agent_knowledge

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api


# Model Adapter Configuration (真实密钥只写本地 .env，不提交仓库)
# Shared OpenAI-compatible gateway, optional fallback for LLM / embedding / reranker.
MODEL_PROVIDER=openai-compatible
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_TIMEOUT_SECONDS=60
MODEL_MAX_RETRIES=2

# LLM adapter
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# Embedding adapter
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=10

# Rerank adapter
RERANK_PROVIDER=openai-compatible
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
RERANK_API_KEY=
RERANK_MODEL=qwen3-rerank
RERANK_TOP_N=10

# Backward-compatible names used by early adapter drafts
OPENAI_API_KEY=
OPENAI_BASE_URL=
DEFAULT_LLM_MODEL=
DEFAULT_EMBEDDING_MODEL=text-embedding-v4
DEFAULT_RERANK_MODEL=qwen3-rerank
